<Window x:Class="PhotoBIZ.WindowsAgent.ControlCenter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PhotoBIZ Agent Control Center"
        Width="1040"
        Height="720"
        MinWidth="920"
        MinHeight="620"
        Loaded="OnLoaded"
        Closing="OnClosing"
        Closed="OnClosed"
        StateChanged="OnStateChanged"
        Background="{StaticResource AgentBackgroundBrush}">
  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Background="{StaticResource AgentSurfaceBrush}"
            BorderBrush="{StaticResource AgentBorderBrush}"
            BorderThickness="1"
            Padding="18"
            Margin="0,0,0,14">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock Text="PhotoBIZ Agent" FontSize="24" FontWeight="SemiBold" />
          <TextBlock Text="{Binding PairedBoothText}" Foreground="{StaticResource AgentMutedTextBrush}" Margin="0,5,0,0" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <Border BorderBrush="{StaticResource AgentBorderBrush}"
                  BorderThickness="1"
                  Background="{StaticResource AgentBackgroundBrush}"
                  Padding="12,7"
                  Margin="0,0,10,0">
            <TextBlock Text="{Binding RuntimeStatusText}" FontWeight="SemiBold" />
          </Border>
          <CheckBox Content="{Binding ModeText}" IsChecked="{Binding TechnicianMode}" VerticalAlignment="Center" Margin="0,0,14,0" />
          <Button Content="Start Booth" Command="{Binding StartBoothCommand}" Background="{StaticResource AgentAccentBrush}" Foreground="White" />
          <Button Content="Stop Booth" Command="{Binding StopBoothCommand}" />
        </StackPanel>
      </Grid>
    </Border>

    <TabControl Grid.Row="1" Background="{StaticResource AgentSurfaceBrush}" BorderBrush="{StaticResource AgentBorderBrush}">
      <TabItem Header="Dashboard">
        <Grid Margin="18">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <Border Grid.Column="0" Grid.Row="0" BorderBrush="{StaticResource AgentBorderBrush}" BorderThickness="1" Padding="16" Margin="0,0,14,14">
            <UniformGrid Columns="2" Rows="4">
              <StackPanel Margin="0,0,16,14">
                <TextBlock Text="Booth" Foreground="{StaticResource AgentMutedTextBrush}" />
                <TextBlock Text="{Binding BoothCode}" FontSize="18" FontWeight="SemiBold" />
              </StackPanel>
              <StackPanel Margin="0,0,16,14">
                <TextBlock Text="Pairing" Foreground="{StaticResource AgentMutedTextBrush}" />
                <TextBlock Text="{Binding PairingStatusText}" FontSize="18" FontWeight="SemiBold" />
              </StackPanel>
              <StackPanel Margin="0,0,16,14">
                <TextBlock Text="API" Foreground="{StaticResource AgentMutedTextBrush}" />
                <TextBlock Text="{Binding ApiBaseUrl}" FontSize="18" FontWeight="SemiBold" />
              </StackPanel>
              <StackPanel Margin="0,0,16,14">
                <TextBlock Text="Booth UI" Foreground="{StaticResource AgentMutedTextBrush}" />
                <TextBlock Text="{Binding BoothUiBaseUrl}" FontSize="18" FontWeight="SemiBold" />
              </StackPanel>
              <StackPanel Margin="0,0,16,14">
                <TextBlock Text="LumaBooth" Foreground="{StaticResource AgentMutedTextBrush}" />
                <TextBlock Text="{Binding LumaBoothMode}" FontSize="18" FontWeight="SemiBold" />
              </StackPanel>
              <StackPanel Margin="0,0,16,14">
                <TextBlock Text="Kiosk" Foreground="{StaticResource AgentMutedTextBrush}" />
                <TextBlock Text="{Binding KioskModeText}" FontSize="18" FontWeight="SemiBold" />
              </StackPanel>
              <StackPanel Margin="0,0,16,14">
                <TextBlock Text="Version" Foreground="{StaticResource AgentMutedTextBrush}" />
                <TextBlock Text="{Binding AgentVersion}" FontSize="18" FontWeight="SemiBold" />
              </StackPanel>
              <StackPanel Margin="0,0,16,14">
                <TextBlock Text="Last Updated" Foreground="{StaticResource AgentMutedTextBrush}" />
                <TextBlock Text="{Binding LastUpdatedText}" FontSize="18" FontWeight="SemiBold" />
              </StackPanel>
            </UniformGrid>
          </Border>

          <Border Grid.Column="1" Grid.Row="0" BorderBrush="{StaticResource AgentBorderBrush}" BorderThickness="1" Padding="16" Margin="0,0,0,14">
            <StackPanel>
              <TextBlock Text="Runtime" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
              <Button Content="Start Booth" Command="{Binding StartBoothCommand}" Margin="0,0,0,8" />
              <Button Content="Stop Booth" Command="{Binding StopBoothCommand}" Margin="0,0,0,8" />
              <Button Content="Relaunch Booth" Command="{Binding RestartBoothCommand}" Margin="0,0,0,8" />
              <Button Content="Reload Status" Command="{Binding ReloadCommand}" Margin="0" />
            </StackPanel>
          </Border>

          <Border Grid.ColumnSpan="2" Grid.Row="1" BorderBrush="{StaticResource AgentBorderBrush}" BorderThickness="1" Padding="16">
            <StackPanel>
              <TextBlock Text="Status" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
              <TextBlock Text="{Binding StatusMessage}" FontSize="14" />
            </StackPanel>
          </Border>
        </Grid>
      </TabItem>

      <TabItem Header="Pair / Re-pair" Visibility="{Binding TechnicianVisibility}">
        <Grid Margin="18">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <TextBlock Grid.Row="0" Grid.Column="0" Text="API URL" VerticalAlignment="Center" Margin="0,0,12,12" />
          <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ApiBaseUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Booth Code" VerticalAlignment="Center" Margin="0,0,12,12" />
          <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding BoothCode, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Agent Credential" VerticalAlignment="Center" Margin="0,0,12,16" />
          <PasswordBox Grid.Row="2" Grid.Column="1" x:Name="AgentCredentialBox" PasswordChanged="OnAgentCredentialChanged" Margin="0,0,0,16" />

          <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
            <Button Content="Pair" Command="{Binding PairCommand}" Background="{StaticResource AgentPrimaryBrush}" Foreground="White" />
            <Button Content="Re-pair" Command="{Binding RePairCommand}" />
          </StackPanel>
        </Grid>
      </TabItem>

      <TabItem Header="Kiosk / Display" Visibility="{Binding TechnicianVisibility}">
        <Grid Margin="18">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Booth UI URL" VerticalAlignment="Center" Margin="0,0,12,12" />
          <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding BoothUiBaseUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Chrome Path" VerticalAlignment="Center" Margin="0,0,12,12" />
          <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Text="{Binding ChromeExecutablePath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
            <Button Grid.Column="1" Content="Detect" Command="{Binding DetectChromeCommand}" Margin="0" />
          </Grid>

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Chrome Profile" VerticalAlignment="Center" Margin="0,0,12,12" />
          <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ChromeUserDataDir, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Launch Booth UI" VerticalAlignment="Center" Margin="0,0,12,12" />
          <CheckBox Grid.Row="3" Grid.Column="1" IsChecked="{Binding LaunchBoothUiOnStartup}" VerticalAlignment="Center" Margin="0,0,0,12" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Kiosk Mode" VerticalAlignment="Center" Margin="0,0,12,12" />
          <CheckBox Grid.Row="4" Grid.Column="1" IsChecked="{Binding KioskMode}" VerticalAlignment="Center" Margin="0,0,0,12" />

          <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding ChromeExecutablePathText}" Foreground="{StaticResource AgentMutedTextBrush}" Margin="0,0,0,12" />

          <Button Grid.Row="6" Grid.Column="1" Content="Save Kiosk Settings" Command="{Binding SaveDisplaySettingsCommand}" HorizontalAlignment="Left" />
        </Grid>
      </TabItem>

      <TabItem Header="LumaBooth" Visibility="{Binding TechnicianVisibility}">
        <Grid Margin="18">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Mode" VerticalAlignment="Center" Margin="0,0,12,12" />
          <ComboBox Grid.Row="0" Grid.Column="1"
                    ItemsSource="{Binding LumaBoothModeOptions}"
                    SelectedItem="{Binding LumaBoothMode}"
                    MinHeight="34"
                    Margin="0,0,0,12" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="API URL" VerticalAlignment="Center" Margin="0,0,12,12" />
          <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding LumaBoothApiBaseUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Trigger Listener" VerticalAlignment="Center" Margin="0,0,12,12" />
          <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding LumaBoothTriggerListenerUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Start Timeout" VerticalAlignment="Center" Margin="0,0,12,12" />
          <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding LumaBoothStartTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="API Password" VerticalAlignment="Center" Margin="0,0,12,16" />
          <PasswordBox Grid.Row="4" Grid.Column="1" x:Name="LumaBoothApiPasswordBox" PasswordChanged="OnLumaBoothApiPasswordChanged" Margin="0,0,0,16" />

          <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal">
            <TextBlock Text="{Binding LumaBoothPasswordStatusText}" Foreground="{StaticResource AgentMutedTextBrush}" VerticalAlignment="Center" Margin="0,0,16,0" />
            <Button Content="Save LumaBooth Settings" Command="{Binding SaveLumaBoothSettingsCommand}" />
            <Button Content="Test API" Command="{Binding TestLumaBoothCommand}" />
          </StackPanel>
        </Grid>
      </TabItem>

      <TabItem Header="Logs">
        <Grid Margin="18">
          <TextBox Text="{Binding RecentLogText, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />
        </Grid>
      </TabItem>

      <TabItem Header="Diagnostics">
        <Grid Margin="18">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <Button Grid.Row="0" Content="Export Diagnostics" Command="{Binding ExportDiagnosticsCommand}" HorizontalAlignment="Left" Margin="0,0,0,12" />
          <TextBox Grid.Row="1" Text="{Binding DiagnosticSummaryText, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />
        </Grid>
      </TabItem>

      <TabItem Header="About">
        <StackPanel Margin="18">
          <TextBlock Text="PhotoBIZ Agent Control Center" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8" />
          <TextBlock Text="{Binding AgentVersion}" Margin="0,0,0,8" />
          <TextBlock Text="Manual installer updates are used for v1." Foreground="{StaticResource AgentMutedTextBrush}" />
        </StackPanel>
      </TabItem>
    </TabControl>

    <StatusBar Grid.Row="2" Margin="0,14,0,0" Background="{StaticResource AgentSurfaceBrush}">
      <StatusBarItem>
        <TextBlock Text="{Binding StatusMessage}" />
      </StatusBarItem>
    </StatusBar>
  </Grid>
</Window>
