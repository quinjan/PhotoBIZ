<Application x:Class="PhotoBIZ.WindowsAgent.ControlCenter.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnMainWindowClose">
  <Application.Resources>
    <SolidColorBrush x:Key="AgentBackgroundBrush" Color="#F6F8FA" />
    <SolidColorBrush x:Key="AgentSurfaceBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="AgentPrimaryBrush" Color="#1C6E8C" />
    <SolidColorBrush x:Key="AgentAccentBrush" Color="#6B8E23" />
    <SolidColorBrush x:Key="AgentBorderBrush" Color="#D7DEE6" />
    <SolidColorBrush x:Key="AgentTextBrush" Color="#1E2933" />
    <SolidColorBrush x:Key="AgentMutedTextBrush" Color="#64748B" />

    <Style TargetType="{x:Type TextBlock}">
      <Setter Property="Foreground" Value="{StaticResource AgentTextBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style TargetType="{x:Type TextBox}">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="8,5" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style TargetType="{x:Type PasswordBox}">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="8,5" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style TargetType="{x:Type Button}">
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="MinWidth" Value="96" />
      <Setter Property="Padding" Value="14,6" />
      <Setter Property="Margin" Value="0,0,8,0" />
    </Style>
  </Application.Resources>
</Application>
