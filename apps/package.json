{
  "name": "photobiz-web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start:admin": "ng serve admin-web",
    "start:booth": "ng serve booth-ui --port 4201",
    "build": "npm run build:admin && npm run build:booth",
    "build:admin": "ng build admin-web",
    "build:booth": "ng build booth-ui",
    "test": "ng test",
    "test:ci": "ng test --watch=false",
    "lint": "npm run format:check",
    "format:check": "prettier --check \"projects/**/*.{ts,html,scss,json}\""
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/cdk": "^21.2.10",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.10",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.10",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
